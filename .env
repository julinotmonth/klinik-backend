PORT=4000

# Opsi 1: gunakan connection string lengkap
DATABASE_URL=postgres://klinik_user:klinik_pass@localhost:5000/klinik_db


# Opsi 2: atau isi satu-per-satu (dipakai jika DATABASE_URL kosong)
PGHOST=localhost
PGPORT=5000
PGDATABASE=klinik_db
PGUSER=klinik_user
PGPASSWORD=klinik_pass

# Set ke "true" jika server PostgreSQL mewajibkan SSL (mis. layanan cloud)
PGSSL=false

JWT_SECRET=ganti_dengan_secret_yang_sangat_rahasia
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173
